{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile for C++",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++23",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}\\build\\cpp.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}