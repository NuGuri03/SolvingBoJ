{
    "version": "2.0.0",
    "runner": "terminal",
    "type": "shell",
    "echoCommand": true,
    "presentation": { "reveal": "always" },
    "tasks": [
        {
            "label": "compile for C/C++",
            "command": "g++",
            "args": [
                "-std=c++23",
                "-I",
                "${workspaceFolder}\\include",
                "${file}",
                "-o",
                "${workspaceFolder}\\build\\cpp.exe"
            ],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": {
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        }
    ]
}